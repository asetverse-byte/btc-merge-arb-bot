# Copy to .env.live and fill carefully.
# This file sends real orders only when LIVE_ARMED is exactly this value.
LIVE_ARMED=

PRIVATE_KEY=
DEPOSIT_WALLET_ADDRESS=
SIGNATURE_TYPE=3

# Small-account live guards
LIVE_QUOTE_USD=2.50
LIVE_MIN_QUOTE_SHARES=5
LIVE_MAX_SIDE_SHARES=5
LIVE_MAX_TOTAL_SHARES=10
LIVE_MAX_GLOBAL_USD=30.00
LIVE_MAX_ACTIVE_INVENTORY_MARKETS=4
LIVE_MAX_MARKET_USD=6.00
LIVE_MAX_PAIR_COST=0.97
LIVE_REPAIR_MAX_PAIR_COST=1.00
LIVE_MIN_MERGE_PROFIT=0.003
LIVE_MIN_MERGE_SHARES=0.10
LIVE_EXIT_BEFORE_CLOSE_MINUTES=5
LIVE_EMERGENCY_PAIR_BEFORE_CLOSE=true
LIVE_EMERGENCY_MAX_PAIR_COST=1.00
LIVE_QUOTE_TTL_SECONDS=20
LIVE_SCAN_INTERVAL_SECONDS=5
LIVE_CANCEL_SETTLE_MS=2000
LIVE_CANCEL_ALL_ON_START=true
LIVE_CANCEL_ONLY=false
LIVE_MAX_QUOTE_CYCLES=0
LIVE_STOP_AFTER_FILL=false
LIVE_DEBUG_RECONCILE=false
LIVE_AUTO_MERGE=true
LIVE_AUTO_DEPLOY_SAFE=true

# Market filter
MARKET_KEYWORDS=btc,bitcoin,eth,ethereum,sol,solana,xrp
MARKET_REQUIRED_TEXT=up or down
MARKET_SEARCH_QUERIES=bitcoin up or down,ethereum up or down,solana up or down,xrp up or down
MAX_MARKETS_PER_SCAN=4

# CLOB / chain
CLOB_HOST=https://clob.polymarket.com
GAMMA_MARKETS_URL=https://gamma-api.polymarket.com/markets
GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events
GAMMA_PUBLIC_SEARCH_URL=https://gamma-api.polymarket.com/public-search
CLOB_BOOK_URL=https://clob.polymarket.com/book
CHAIN_ID=137
RPC_URL=https://polygon-rpc.com

# Relayer merge. SAFE/PROXY execute flow is supported by the official relayer
# client. Deposit-wallet merge may need Polymarket's deposit-wallet relayer
# flow if execute() is rejected.
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
