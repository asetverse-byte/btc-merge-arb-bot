# SCAN = print quote plans only
# MM_PAPER = simulate maker quotes, inventory, and auto-merge
# LIVE = blocked until real CLOB + relayer adapters are wired
EXECUTION_MODE=MM_PAPER

SCAN_INTERVAL_SECONDS=10
RUN_ONCE=false
MAX_MARKETS_PER_SCAN=5
MARKET_KEYWORDS=btc,bitcoin,eth,ethereum,sol,solana,xrp
MARKET_REQUIRED_TEXT=up or down

PAPER_START_BALANCE=20
PAPER_LEDGER_FILE=paper_mm_trades.csv

MM_QUOTE_USD=0.25
MM_MAX_MARKET_USD=1.00
MM_TICK=0.01
MM_MIN_QUOTE_PRICE=0.03
MM_MAX_QUOTE_PRICE=0.97
MM_MAX_PAIR_COST=0.97
MM_MIN_MERGE_PROFIT=0.003
MM_MIN_MERGE_SHARES=0.10
MM_FILL_WHEN_CROSSED=true
MM_ASSUME_FILL_PROBABILITY_BPS=2500

GAMMA_MARKETS_URL=https://gamma-api.polymarket.com/markets
GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events
CLOB_BOOK_URL=https://clob.polymarket.com/book

PRIVATE_KEY=
FUNDER_ADDRESS=
WALLET_ADDRESS=
